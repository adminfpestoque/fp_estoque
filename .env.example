DJANGO_SECRET_KEY=troque-esta-chave-por-uma-chave-forte
DEBUG=true
ALLOW_LAN_DEV=true

# Projeto Supabase
SUPABASE_PROJECT_ID=SEU_PROJECT_REF
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Session Pooler recomendado para redes IPv4. Substitua somente SUA_SENHA_DO_BANCO.
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA_DO_BANCO@HOST_DO_POOLER:5432/postgres?sslmode=require
DB_CONN_MAX_AGE=60

# Imagens de produtos no Supabase Storage. A service role é opcional e deve existir somente no .env local/servidor.
SUPABASE_STORAGE_BUCKET=product-images
SUPABASE_SERVICE_ROLE_KEY=

# Em desenvolvimento, ALLOW_LAN_DEV=true permite acesso pelo IP local e CORS em redes privadas.
# Em produção, use ALLOW_LAN_DEV=false e informe apenas hosts/origens autorizados.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Opcional. Quando vazio, o frontend detecta automaticamente o mesmo IP usado no navegador e utiliza a porta 8000.
VITE_API_URL=
API_PAGE_SIZE=20
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Administrador inicial (a senha pode ficar vazia para ser solicitada no terminal).
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_FULL_NAME=Administrador FP Estoque
ADMIN_PASSWORD=
